# ═══════════════════════════════════════════════════════════════
# Iengine — AI Visual Journalism Intelligence Engine
# Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ─── ComfyUI ──────────────────────────────────────────────────
COMFYUI_URL=http://localhost:8188

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
IENGINE_REDIS_DB=2

# ─── Backend API ──────────────────────────────────────────────
BACKEND_API_URL=http://localhost:4000
IENGINE_SERVICE_TOKEN=

# ─── CDN / Storage ───────────────────────────────────────────
CDN_PROVIDER=backblaze-b2
CDN_URL=https://cdn.sygn.live
CDN_BUCKET=coindaily-media

# ─── Generation Settings ─────────────────────────────────────
IENGINE_MAX_CONCURRENCY=2
IENGINE_DEFAULT_TIMEOUT=120000
IENGINE_MAX_RETRIES=3
IENGINE_QUALITY_SCORING=true
IENGINE_THUMBNAILS=true
IENGINE_UPSCALING=true

# ─── Quality Scoring ─────────────────────────────────────────
CLIP_SCORING_URL=http://localhost:8100/score
AESTHETIC_SCORING_URL=http://localhost:8101/score
IENGINE_MIN_QUALITY=0.72
IENGINE_AUTO_REJECT=true

# ─── Workers ─────────────────────────────────────────────────
IENGINE_GPU_COUNT=1
IENGINE_CONCURRENCY_PER_GPU=1
