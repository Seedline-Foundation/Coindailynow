PORT=3005
NODE_ENV=development

# Database — self-hosted Postgres (Contabo) is the launch default.
# Supabase tenancy is retired; see documentations/launch/CFIS_DB_MIGRATION.md.
#
# Local dev (docker-compose network):
DATABASE_URL=postgres://cfis:cfis_dev_password_change_me@cfis-postgres:5432/cfis_db
# Local dev (host network — when Postgres is bound to 127.0.0.1:5432):
# DATABASE_URL=postgres://cfis:cfis_dev_password_change_me@127.0.0.1:5432/cfis_db

# Legacy individual params (fallback if DATABASE_URL is unset).
DB_HOST=cfis-postgres
DB_PORT=5432
DB_USER=cfis
DB_PASSWORD=cfis_dev_password_change_me
DB_NAME=cfis_db
DB_SSL=false
DB_POOL_MAX=10

# AI — DeepSeek R1 via Ollama (self-hosted)
OLLAMA_URL=http://localhost:11434
AI_MODEL=deepseek-r1

# Blockchain
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key
JOY_TOKEN_ADDRESS=0x...
PRIVATE_KEY=your-private-key

# Payments
STRIPE_SECRET_KEY=sk_test_...

# CFIS Security
CFIS_JWT_SECRET=cfis-super-secret-key-change-in-production
CFIS_ADMIN_PASSWORD=cfis-admin-2026
SUPER_ADMIN_EMAILS=admin@coindaily.online
CFIS_HMAC_SECRET=cfis-hmac-secret-change-in-production

# CFIS → backend reverse webhook leg (issues receipts + reconciles)
BACKEND_API_URL=http://localhost:4000
BACKEND_HMAC_SECRET=cfis-hmac-secret-change-in-production
