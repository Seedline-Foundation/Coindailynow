PORT=3005
NODE_ENV=development

# Database — Supabase PostgreSQL
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-eu-central-2.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-eu-central-2.pooler.supabase.com:6543/postgres?sslmode=require

# Legacy individual params (fallback if DATABASE_URL not set)
DB_HOST=aws-1-eu-central-2.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.YOUR_PROJECT
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=postgres
DB_SSL=true

# AI — DeepSeek R1 via Ollama (self-hosted)
OLLAMA_URL=http://localhost:11434
AI_MODEL=deepseek-r1

# Blockchain
RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key
JOY_TOKEN_ADDRESS=0x...
PRIVATE_KEY=your-private-key

# Payments
STRIPE_SECRET_KEY=sk_test_...

# CFIS Security
CFIS_JWT_SECRET=cfis-super-secret-key-change-in-production
CFIS_ADMIN_PASSWORD=cfis-admin-2026
SUPER_ADMIN_EMAILS=admin@coindaily.online
CFIS_HMAC_SECRET=cfis-hmac-secret-change-in-production
