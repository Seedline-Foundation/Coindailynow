# CoinDaily DB stack env template.
# Copy to `.env` on the Contabo VPS only. NEVER commit the real file.
#
#   cp .env.example .env
#   # generate a strong password:
#   openssl rand -base64 32 | tr -d '=+/\n'
#   # paste it into POSTGRES_PASSWORD below

POSTGRES_USER=coindaily
POSTGRES_DB=coindaily_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Host bind-mount paths. Defaults to ~/coindaily/{pgdata,backups}.
# Override only if you relocate the data directory.
HOST_PGDATA_DIR=${HOME}/coindaily/pgdata
HOST_BACKUPS_DIR=${HOME}/coindaily/backups

# Timescale tuning (adjust to VPS spec).
TS_TUNE_MEMORY=4GB
TS_TUNE_NUM_CPUS=2
