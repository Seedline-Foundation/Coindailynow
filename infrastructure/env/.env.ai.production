# AI System Production Environment
# ai.coindaily.online

NODE_ENV=production
PORT=4001

# Service URLs
NLLB_SERVICE_URL=http://localhost:8080
EMBEDDINGS_SERVICE_URL=http://localhost:8081
OLLAMA_URL=http://localhost:11434

# Backend Integration
BACKEND_URL=https://backend.coindaily.online
BACKEND_API_KEY=your_internal_api_key

# Model Configuration
DEFAULT_LLM_MODEL=llama3.1:8b
REVIEW_MODEL=deepseek-r1:8b
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Task Queue
REDIS_URL=redis://localhost:6379
TASK_QUEUE_PREFIX=ai:tasks

# Performance
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT_MS=300000
MAX_RETRIES=3

# Logging
LOG_LEVEL=info
LOG_AI_REQUESTS=true
LOG_AI_RESPONSES=false  # Set to false to avoid logging large responses

# African Market Specialization
ENABLE_AFRICAN_MARKET_ANALYSIS=true
TRACKED_EXCHANGES=binance_africa,luno,quidax,buycoins,valr

# Content Generation
MAX_ARTICLE_LENGTH=5000
DEFAULT_LANGUAGES=en,sw,ha,yo,ig
