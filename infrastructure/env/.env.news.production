# News Frontend Production Environment
# sygn.live

NODE_ENV=production
PORT=3000

# API URLs
NEXT_PUBLIC_API_URL=https://backend.sygn.live
NEXT_PUBLIC_AI_URL=https://ai.sygn.live
NEXT_PUBLIC_WS_URL=wss://backend.sygn.live/ws

# Site Info
NEXT_PUBLIC_SITE_URL=https://sygn.live
NEXT_PUBLIC_SITE_NAME="CoinDaily"
NEXT_PUBLIC_SITE_DESCRIPTION="Africa's Premier Cryptocurrency News Platform"

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Features
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true

# Social
NEXT_PUBLIC_TWITTER_HANDLE=@coindaily
NEXT_PUBLIC_FACEBOOK_APP_ID=your_fb_app_id
