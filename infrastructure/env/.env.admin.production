# Admin Portal Production Environment
# jet.sygn.live

NODE_ENV=production
PORT=3002

# API URLs
NEXT_PUBLIC_API_URL=https://backend.sygn.live
NEXT_PUBLIC_AI_URL=https://ai.sygn.live
NEXT_PUBLIC_WS_URL=wss://backend.sygn.live/ws

# Site Info
NEXT_PUBLIC_SITE_URL=https://jet.sygn.live
NEXT_PUBLIC_SITE_NAME="CoinDaily Admin"
NEXT_PUBLIC_SITE_DESCRIPTION="CoinDaily Administration Portal"

# Admin Mode
ADMIN_MODE=true
NEXT_PUBLIC_ADMIN_MODE=true

# Security
SESSION_TIMEOUT_MINUTES=15
REQUIRE_2FA=true
MAX_LOGIN_ATTEMPTS=3
LOCKOUT_DURATION_MINUTES=30

# Features (Admin specific)
NEXT_PUBLIC_ENABLE_FUNDS_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_USER_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_AI_CONTROL=true
NEXT_PUBLIC_ENABLE_PR_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_ANALYTICS_DASHBOARD=true

# Audit Logging
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=365
