# PR System Production Environment
# pr.coindaily.online

NODE_ENV=production
PORT=3003

# API URLs
NEXT_PUBLIC_API_URL=https://backend.coindaily.online
NEXT_PUBLIC_AI_URL=https://ai.coindaily.online
NEXT_PUBLIC_WS_URL=wss://backend.coindaily.online/ws

# Site Info
NEXT_PUBLIC_SITE_URL=https://pr.coindaily.online
NEXT_PUBLIC_SITE_NAME="CoinDaily PR"
NEXT_PUBLIC_SITE_DESCRIPTION="CoinDaily PR & Ad Distribution Network"

# PR Mode
PR_MODE=true
NEXT_PUBLIC_PR_MODE=true

# Features (PR specific)
NEXT_PUBLIC_ENABLE_CAMPAIGN_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_OPERATOR_DASHBOARD=true
NEXT_PUBLIC_ENABLE_PAYMENT_PROCESSING=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Token Integration
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS=your_token_contract_address
NEXT_PUBLIC_CHAIN_ID=1  # or appropriate chain

# Payment Processing
ADMIN_PAYMENT_WEBHOOK=https://jet.coindaily.online/api/payments/webhook
