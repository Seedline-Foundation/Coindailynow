# Backend API Production Environment
# backend.coindaily.online

NODE_ENV=production
PORT=4000

# Database - Supabase
SUPABASE_URL="https://auakxtwvqqefysprkczv.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your_production_jwt_secret_min_64_chars"
JWT_REFRESH_SECRET="your_production_jwt_refresh_secret_min_64_chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# AI Services
AI_SERVICE_URL="https://ai.coindaily.online"
NLLB_SERVICE_URL="http://localhost:8080"
EMBEDDINGS_SERVICE_URL="http://localhost:8081"
OLLAMA_URL="http://localhost:11434"

# Frontend URLs
FRONTEND_URL="https://coindaily.online"
ADMIN_URL="https://jet.coindaily.online"
PR_URL="https://pr.coindaily.online"

# Cloudflare
CLOUDFLARE_API_TOKEN="your_cloudflare_token"
CLOUDFLARE_ZONE_ID="your_zone_id"

# Backblaze Storage
BACKBLAZE_APPLICATION_KEY_ID="your_backblaze_key_id"
BACKBLAZE_APPLICATION_KEY="your_backblaze_key"
BACKBLAZE_BUCKET_NAME="coindaily-media"

# Email Service
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@coindaily.online"
SMTP_PASS="your_smtp_password"

# Logging
LOG_LEVEL="info"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Security
CORS_ORIGINS="https://coindaily.online,https://jet.coindaily.online,https://pr.coindaily.online"
