# CoinDaily Backend - Production Environment Variables
# Copy this file to .env and fill in your actual values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# Contabo self-hosted Postgres 16 + TimescaleDB (Production)
# Provisioned via infrastructure/db/docker-compose.db.yml. Bound to loopback.
DATABASE_URL="postgresql://coindaily:REPLACE_WITH_STRONG_PASSWORD@127.0.0.1:5432/coindaily_prod?sslmode=disable&connection_limit=20"
DIRECT_URL="postgresql://coindaily:REPLACE_WITH_STRONG_PASSWORD@127.0.0.1:5432/coindaily_prod?sslmode=disable"

# --- Legacy Supabase (kept for rollback only; remove once Contabo cutover is stable) ---
# DATABASE_URL="postgresql://postgres.[your-project-ref]:password@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require"
# DIRECT_URL="postgresql://postgres.[your-project-ref]:password@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require"
# SUPABASE_URL="https://[your-project-ref].supabase.co"
# SUPABASE_ANON_KEY="your-supabase-anon-key"
# SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# ==========================================
# REDIS CONFIGURATION
# ==========================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
REDIS_DB=0

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Generate secure secrets: openssl rand -base64 32
JWT_SECRET="your-super-secure-jwt-secret-minimum-32-characters-long"
JWT_REFRESH_SECRET="your-super-secure-refresh-secret-minimum-32-characters-long"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ==========================================
# SERVER CONFIGURATION
# ==========================================
NODE_ENV="production"
PORT=4000
FRONTEND_URL="https://mvp.sygn.live"
BACKEND_URL="https://mvp.sygn.live/api"

# ==========================================
# CORS CONFIGURATION
# ==========================================
ALLOWED_ORIGINS="https://mvp.sygn.live,https://sygn.live,https://app.sygn.live,https://backend.sygn.live,https://jet.sygn.live,https://press.sygn.live,https://pr.sygn.live,https://ai.sygn.live,https://cabfi.xyz"

# ==========================================
# AI SERVICES (Self-Hosted via Ollama + Docker)
# ==========================================
# Llama 3.1 8B for content generation (via Ollama)
LLAMA_API_ENDPOINT="http://localhost:11434"
LLAMA_MODEL="llama3.1:8b"

# DeepSeek R1 8B for review & reasoning (via Ollama)
DEEPSEEK_API_ENDPOINT="http://localhost:11435"
DEEPSEEK_MODEL="deepseek-r1:8b"

# NLLB-200 for translation (Docker container)
NLLB_API_ENDPOINT="http://localhost:8080"

# SDXL for image generation (Docker container)
SDXL_API_ENDPOINT="http://localhost:7860"

# BGE Embeddings for RAG (Docker container)
EMBEDDING_API_ENDPOINT="http://localhost:8081"

# Perspective API for moderation
PERSPECTIVE_API_KEY="your-perspective-api-key"

# ==========================================
# EXTERNAL APIS
# ==========================================
# CoinGecko for market data
COINGECKO_API_KEY="your-coingecko-api-key"

# Binance API (optional)
BINANCE_API_KEY="your-binance-api-key"
BINANCE_API_SECRET="your-binance-api-secret"

# ==========================================
# CLOUDFLARE CDN (Optional)
# ==========================================
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_ZONE_ID="your-zone-id"
CLOUDFLARE_ACCOUNT_ID="your-account-id"

# ==========================================
# EMAIL SERVICE
# ==========================================
# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@sygn.live"

# ==========================================
# FILE STORAGE
# ==========================================
# Backblaze B2 for media storage
B2_APPLICATION_KEY_ID="your-b2-key-id"
B2_APPLICATION_KEY="your-b2-application-key"
B2_BUCKET_NAME="coindaily-media"
B2_ENDPOINT="s3.us-west-000.backblazeb2.com"

# Alternative: Cloudflare R2
# R2_ACCOUNT_ID="your-account-id"
# R2_ACCESS_KEY_ID="your-access-key"
# R2_SECRET_ACCESS_KEY="your-secret-key"
# R2_BUCKET_NAME="coindaily-media"

# ==========================================
# ELASTICSEARCH
# ==========================================
ELASTICSEARCH_NODE="http://localhost:9200"
ELASTICSEARCH_USERNAME=""
ELASTICSEARCH_PASSWORD=""

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_GRAPHQL_MAX=50

# ==========================================
# SECURITY
# ==========================================
# Bcrypt rounds for password hashing
BCRYPT_ROUNDS=12

# Session secret
SESSION_SECRET="your-super-secure-session-secret-minimum-32-characters"

# Cookie settings
COOKIE_DOMAIN="sygn.live"
COOKIE_SECURE=true
COOKIE_SAME_SITE="strict"

# ==========================================
# MONITORING & LOGGING
# ==========================================
LOG_LEVEL="info"
ENABLE_QUERY_LOGGING=false
ENABLE_ERROR_REPORTING=true

# Sentry for error tracking (optional)
SENTRY_DSN="your-sentry-dsn"
SENTRY_ENVIRONMENT="production"

# ==========================================
# CRON JOBS & BACKGROUND TASKS
# ==========================================
ENABLE_CRON_JOBS=true
ENABLE_AI_AGENTS=true

# ==========================================
# WEBHOOK URLs
# ==========================================
DISCORD_WEBHOOK_URL="your-discord-webhook-url"
SLACK_WEBHOOK_URL="your-slack-webhook-url"

# ==========================================
# BLOCKCHAIN (for Finance Features)
# ==========================================
# Ethereum/Polygon RPC
ETH_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/your-api-key"
POLYGON_RPC_URL="https://polygon-mainnet.g.alchemy.com/v2/your-api-key"

# Wallet connect project ID
WALLET_CONNECT_PROJECT_ID="your-project-id"

# ==========================================
# ANALYTICS
# ==========================================
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
MIXPANEL_TOKEN="your-mixpanel-token"

# ==========================================
# NEWSLETTER (Listmonk — self-hosted)
# ==========================================
# Listmonk runs as a Docker container on the same Contabo VPS.
# Admin UI: http://127.0.0.1:9000 (proxy via nginx for external access)
LISTMONK_URL="http://127.0.0.1:9000"
LISTMONK_ADMIN_USER="admin"
LISTMONK_ADMIN_PASSWORD="CHANGE_ME"
# List ID for the daily brief (created in Listmonk admin after first boot)
LISTMONK_DAILY_BRIEF_LIST_ID=1

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_PREMIUM_CONTENT=true
ENABLE_WALLET_FEATURES=false
ENABLE_AI_TRANSLATION=true
ENABLE_COMMUNITY_FEATURES=true
ENABLE_FRAUD_DETECTION=true

# ==========================================
# API KEYS FOR INTEGRATIONS
# ==========================================
# Twitter/X API
TWITTER_API_KEY="your-twitter-api-key"
TWITTER_API_SECRET="your-twitter-api-secret"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# PayPal API
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"

# ==========================================
# MISC
# ==========================================
APP_NAME="CoinDaily"
APP_VERSION="1.0.0"
SUPPORT_EMAIL="support@sygn.live"
