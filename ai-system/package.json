{
  "name": "coindaily-ai-system",
  "version": "1.0.0",
  "description": "CoinDaily AI Agent System - Content Generation, Translation, and Analysis",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./orchestrator": "./dist/orchestrator/index.js",
    "./agents/review": "./dist/agents/review/aiReviewAgent.js",
    "./agents/research": "./dist/agents/research/researchAgent.js",
    "./agents/image": "./dist/agents/image/imageAgent.js",
    "./agents/translation": "./dist/agents/translation/translationAgentForReview.js",
    "./agents/moderation": "./dist/agents/moderation/contentModerationAgent.js",
    "./types": "./dist/types/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/orchestrator/index.js",
    "dev": "ts-node-dev --respawn --transpile-only orchestrator/index.ts",
    "test": "jest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agents",
    "content-generation",
    "translation",
    "cryptocurrency"
  ],
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.0",
    "ioredis": "^5.8.1",
    "prisma": "^5.7.0",
    "winston": "^3.11.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  }
}
