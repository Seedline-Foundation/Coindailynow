# ============================================
# CoinDaily Platform - Environment Variables
# ============================================
# Copy this file to .env and fill in real values
# NEVER commit .env with real secrets to git
# ============================================

# ─── DATABASE ARCHITECTURE ──────────────────────────────────────
# 1. Postgres (self-hosted on Contabo) → transactional data
# 2. PostHog (EU cloud)                → user behavior & product events
# 3. TimescaleDB (extension on Postgres) → time-series market data (OHLC, ticks)
# ─────────────────────────────────────────────────────────────────

# Self-Hosted PostgreSQL + TimescaleDB (Contabo VPS)
# After migration from Supabase, update these to your Contabo server address
DATABASE_URL="postgresql://coindaily:YOUR_STRONG_PASSWORD@localhost:5432/coindaily?schema=public"
DIRECT_URL="postgresql://coindaily:YOUR_STRONG_PASSWORD@localhost:5432/coindaily?schema=public"

# Legacy Supabase (keep until migration is complete, then remove)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
SUPABASE_PUBLISHABLE_KEY="your_supabase_publishable_key"

# Redis & Elasticsearch
REDIS_URL="redis://localhost:6379"
REDIS_ENABLED="true"
ELASTICSEARCH_URL="http://localhost:9200"

# Authentication — CHANGE THESE IN PRODUCTION (use: openssl rand -base64 64)
JWT_SECRET="CHANGE_ME_use_openssl_rand_base64_64"
JWT_REFRESH_SECRET="CHANGE_ME_use_openssl_rand_base64_64"

# AI Service Configuration
OPENAI_API_KEY="your_openai_api_key"
GOOGLE_AI_API_KEY="your_google_ai_api_key"
NLLB_SERVICE_URL="http://localhost:8080"

# External Services
CLOUDFLARE_API_TOKEN="your_cloudflare_token"
BACKBLAZE_APPLICATION_KEY_ID="your_backblaze_key_id"
BACKBLAZE_APPLICATION_KEY="your_backblaze_key"

# African Exchange APIs
BINANCE_AFRICA_API_KEY="your_binance_africa_key"
LUNO_API_KEY="your_luno_key"
QUIDAX_API_KEY="your_quidax_key"

# PostHog — Product Analytics (user behavior / events — separate from transactional DB)
POSTHOG_API_KEY="phc_YOUR_POSTHOG_PROJECT_KEY"
POSTHOG_HOST="https://eu.i.posthog.com"

# Server Configuration
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:3000"

# Logging
LOG_LEVEL="info"

# Cache Configuration
CACHE_TTL_ARTICLES=3600
CACHE_TTL_MARKET_DATA=30
CACHE_TTL_USER_DATA=300

# Rate Limiting
RATE_LIMIT_FREE_TIER=100
RATE_LIMIT_PREMIUM_TIER=1000
RATE_LIMIT_ENTERPRISE_TIER=10000

# AI Services (local or via SSH tunnel)
NLLB_API_URL=http://localhost:8080
EMBEDDINGS_API_URL=http://localhost:8081
SDXL_API_URL=http://localhost:7860
OLLAMA_API_URL=http://localhost:11434

# ============================================================================
# Wallet System Configuration
# ============================================================================

# CE to JY Token Conversion
CE_TO_JY_CONVERSION_RATE=0.01        # 100 CE Points = 1 JY Token
PLATFORM_TRANSFER_FEE=0.01            # 1% platform fee on transfers

# YellowCard Payment Provider (African Markets)
YELLOWCARD_API_URL=https://api.yellowcard.io/v1
YELLOWCARD_API_KEY=your_yellowcard_api_key_here
YELLOWCARD_WEBHOOK_SECRET=your_yellowcard_webhook_secret_here

# ChangeNOW Payment Provider (International Markets)
CHANGENOW_API_URL=https://api.changenow.io/v2
CHANGENOW_API_KEY=your_changenow_api_key_here
CHANGENOW_WEBHOOK_SECRET=your_changenow_webhook_secret_here
